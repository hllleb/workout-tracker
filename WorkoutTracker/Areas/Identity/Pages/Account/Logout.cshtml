@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<div class="page-header">
    <div>
        <h1>@ViewData["Title"]</h1>
        <p>End your current session securely.</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">
        <div class="auth-card text-center">
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <h2 class="auth-card-title">Ready to leave?</h2>
                <p class="auth-card-subtitle">You are signed in as <strong>@User.Identity?.Name</strong>.</p>
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                    <button type="submit" class="w-100 btn btn-lg btn-primary">Log out</button>
                </form>
            }
            else
            {
                <h2 class="auth-card-title">Signed out</h2>
                <p class="auth-card-subtitle">You have successfully logged out of WorkoutTracker.</p>
                <a class="btn btn-lg btn-primary" asp-page="./Login">Sign in again</a>
            }
        </div>
    </div>
</div>
