@model WorkoutTracker.Models.MealItem

@{
    ViewData["Title"] = "Delete meal item";
    var mealName = ViewData["MealName"] as string;
}

<h1>Delete meal item</h1>
@if (!string.IsNullOrWhiteSpace(mealName))
{
    <p class="text-muted">Meal: <strong>@mealName</strong></p>
}

<h3>Are you sure you want to delete this item?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">Quantity</dt>
        <dd class="col-sm-10">@Model.Quantity @Model.Unit</dd>
        <dt class="col-sm-2">Calories</dt>
        <dd class="col-sm-10">@Model.Calories</dd>
        <dt class="col-sm-2">Macros</dt>
        <dd class="col-sm-10">
            P: @(Model.ProteinG?.ToString("0.##") ?? "-") g,
            C: @(Model.CarbsG?.ToString("0.##") ?? "-") g,
            F: @(Model.FatG?.ToString("0.##") ?? "-") g
        </dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a class="btn btn-link" asp-controller="Meals" asp-action="Details" asp-route-id="@Model.MealId">Back</a>
    </form>
</div>
