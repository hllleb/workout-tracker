@model WorkoutTracker.ViewModels.MealItemEditViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Edit meal item";
    var mealName = ViewData["MealName"] as string;
    var fromFatSecret = Model.ProductId.HasValue && Model.CaloriesPerUnit.HasValue;
}

<div class="page-header">
    <div>
        <h1>Edit meal item</h1>
        @if (!string.IsNullOrWhiteSpace(mealName))
        {
            <p>Meal: <strong>@mealName</strong></p>
        }
    </div>
    <a class="btn btn-outline-secondary" asp-controller="Meals" asp-action="Details" asp-route-id="@Model.MealId">Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
        <div class="panel">
            <form asp-action="Edit" method="post" id="meal-item-form" lang="en">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="MealId" />
                <partial name="_MealItemFormFields" model="Model" />
                <button type="submit" class="btn btn-primary">Save changes</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @if (!fromFatSecret)
    {
        <partial name="_ValidationScriptsPartial" />
    }
    @if (fromFatSecret)
    {
        <script src="~/js/meal-item-form.js" asp-append-version="true"></script>
    }
}
