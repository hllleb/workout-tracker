@model WorkoutTracker.ViewModels.MealItemEditViewModel

@{
    ViewData["Title"] = "FatSecret error";
    var mealName = ViewData["MealName"] as string;
}

<h1>FatSecret error</h1>
@if (!string.IsNullOrWhiteSpace(mealName))
{
    <p class="text-muted">Meal: <strong>@mealName</strong></p>
}

<p class="text-muted">FatSecret data could not be loaded. Please try again later.</p>

<a class="btn btn-link" asp-controller="Foods" asp-action="Search" asp-route-mealId="@Model.MealId">Back to search</a>
