@model WorkoutTracker.ViewModels.ProductsIndexViewModel

@{
    ViewData["Title"] = "Products";
}

<div class="page-header">
    <div>
        <h1>Products</h1>
        <p>Admin panel for cached nutrition products.</p>
    </div>
</div>

<form method="get" class="row g-3 filter-card">
    <div class="col-md-5">
        <label class="form-label" for="search">Search by name</label>
        <input type="text" class="form-control" id="search" name="search" value="@Model.Search" />
    </div>
    <div class="col-md-4">
        <label class="form-label" for="source">Source</label>
        <select class="form-select" id="source" name="source">
            <option value="" selected="@(string.IsNullOrEmpty(Model.Source) ? "selected" : null)">All sources</option>
            @foreach (var availableSource in Model.AvailableSources)
            {
                <option value="@availableSource" selected="@(Model.Source == availableSource ? "selected" : null)">
                    @availableSource
                </option>
            }
        </select>
    </div>
    <div class="col-md-3 d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-secondary">Filter</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Clear</a>
    </div>
</form>

@if (Model.Products.Count == 0)
{
    <div class="empty-state">No products found.</div>
}
else
{
    <div class="table-card">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Source</th>
                    <th>External ID</th>
                    <th>Calories</th>
                    <th>Cached at</th>
                    <th>Meal items</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Products)
            {
                <tr>
                    <td class="fw-semibold">@item.Name</td>
                    <td>@item.Source</td>
                    <td class="text-muted">@item.ExternalId</td>
                    <td>@item.Calories</td>
                    <td>@item.CachedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@item.MealItemCount</td>
                    <td class="table-actions text-end">
                        <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
