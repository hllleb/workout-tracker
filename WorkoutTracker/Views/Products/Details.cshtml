@model WorkoutTracker.Models.Product

@{
    ViewData["Title"] = "Product details";
}

<h1>Product details</h1>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Source</dt>
    <dd class="col-sm-9">@Model.Source</dd>

    <dt class="col-sm-3">External ID</dt>
    <dd class="col-sm-9">@Model.ExternalId</dd>

    <dt class="col-sm-3">Serving</dt>
    <dd class="col-sm-9">
        @(Model.ServingSize?.ToString("0.##") ?? "-")
        @Model.ServingUnit
    </dd>

    <dt class="col-sm-3">Calories</dt>
    <dd class="col-sm-9">@Model.Calories</dd>

    <dt class="col-sm-3">Protein</dt>
    <dd class="col-sm-9">@(Model.ProteinG?.ToString("0.##") ?? "-") g</dd>

    <dt class="col-sm-3">Carbs</dt>
    <dd class="col-sm-9">@(Model.CarbsG?.ToString("0.##") ?? "-") g</dd>

    <dt class="col-sm-3">Fat</dt>
    <dd class="col-sm-9">@(Model.FatG?.ToString("0.##") ?? "-") g</dd>

    <dt class="col-sm-3">Cached at</dt>
    <dd class="col-sm-9">@Model.CachedAt.ToString("yyyy-MM-dd HH:mm")</dd>

    <dt class="col-sm-3">Linked meal items</dt>
    <dd class="col-sm-9">@Model.MealItems.Count</dd>
</dl>

<div>
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
    <a class="btn btn-link" asp-action="Index">Back to list</a>
</div>
