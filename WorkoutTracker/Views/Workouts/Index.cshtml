@model WorkoutTracker.ViewModels.WorkoutsIndexViewModel

@{
    ViewData["Title"] = "Workouts";
}

<div class="page-header">
    <div>
        <h1>Workouts</h1>
        <p>Track sessions and review your training history.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Add workout</a>
</div>

<form method="get" class="row g-3 filter-card">
    <div class="col-md-4">
        <label class="form-label" for="search">Search by name</label>
        <input type="text" class="form-control" id="search" name="search" value="@Model.Search" />
    </div>
    <div class="col-md-3">
        <label class="form-label" for="fromDate">From date</label>
        <input type="date" class="form-control" id="fromDate" name="fromDate"
               value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" />
    </div>
    <div class="col-md-3">
        <label class="form-label" for="toDate">To date</label>
        <input type="date" class="form-control" id="toDate" name="toDate"
               value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" />
    </div>
    <div class="col-md-2 d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-secondary">Filter</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Clear</a>
    </div>
</form>

@if (Model.Workouts.Count == 0)
{
    <div class="empty-state">No workouts found.</div>
}
else
{
    <div class="table-card">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Date</th>
                    <th>Notes</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Workouts)
            {
                <tr>
                    <td class="fw-semibold">@item.Name</td>
                    <td>@item.WorkoutDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-muted">@item.Notes</td>
                    <td class="table-actions text-end">
                        <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
