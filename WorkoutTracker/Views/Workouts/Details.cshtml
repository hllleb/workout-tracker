@model WorkoutTracker.Models.Workout

@{
    ViewData["Title"] = "Workout details";
}

<h1>Workout details</h1>

<div>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">Date</dt>
        <dd class="col-sm-10">@Model.WorkoutDate.ToString("yyyy-MM-dd")</dd>
        <dt class="col-sm-2">Notes</dt>
        <dd class="col-sm-10">@Model.Notes</dd>
        <dt class="col-sm-2">Exercises</dt>
        <dd class="col-sm-10">@Model.ExerciseEntries.Count</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> |
    <a asp-action="Index">Back to list</a>
</div>
