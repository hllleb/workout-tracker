@model WorkoutTracker.ViewModels.ExerciseEntryEditViewModel

@{
    ViewData["Title"] = "Edit exercise";
    var workoutName = ViewData["WorkoutName"] as string;
}

<div class="page-header">
    <div>
        <h1>Edit exercise</h1>
        @if (!string.IsNullOrWhiteSpace(workoutName))
        {
            <p>Workout: <strong>@workoutName</strong></p>
        }
    </div>
    <a class="btn btn-outline-secondary" asp-controller="Workouts" asp-action="Details" asp-route-id="@Model.WorkoutId">Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">
        <div class="panel">
            <form asp-action="Edit" method="post" id="exercise-form">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="WorkoutId" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Exercise name</label>
                    <input asp-for="Name" class="form-control" list="exercise-suggestions" autocomplete="off" />
                    <datalist id="exercise-suggestions">
                        <option value="Bench press"></option>
                        <option value="Squat"></option>
                        <option value="Deadlift"></option>
                        <option value="Overhead press"></option>
                        <option value="Barbell row"></option>
                        <option value="Pull-up"></option>
                        <option value="Dip"></option>
                        <option value="Bicep curl"></option>
                        <option value="Tricep extension"></option>
                        <option value="Leg press"></option>
                        <option value="Leg curl"></option>
                        <option value="Lat pulldown"></option>
                        <option value="Romanian deadlift"></option>
                        <option value="Plank"></option>
                        <option value="Running"></option>
                        <option value="Jogging"></option>
                        <option value="Walking"></option>
                        <option value="Cycling"></option>
                        <option value="Swimming"></option>
                        <option value="Rowing"></option>
                        <option value="Jump rope"></option>
                        <option value="HIIT"></option>
                    </datalist>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Exercise type</label>
                    <div class="d-flex gap-3">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="ExerciseType" id="typeStrength" value="Strength" />
                            <label class="form-check-label fw-semibold" for="typeStrength">Strength / gym</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="ExerciseType" id="typeCardio" value="Cardio" />
                            <label class="form-check-label fw-semibold" for="typeCardio">Cardio / endurance</label>
                        </div>
                    </div>
                </div>

                <div id="strength-fields">
                    <div class="mb-3">
                        <label asp-for="Sets" class="form-label">Number of sets</label>
                        <input asp-for="Sets" id="sets-input" class="form-control" type="number" min="1" max="20" style="max-width:120px" />
                        <span asp-validation-for="Sets" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Repetitions per set</label>
                        <div id="reps-container" class="d-flex flex-wrap gap-2">
                            @for (var i = 0; i < Model.Sets; i++)
                            {
                                var reps = Model.RepsPerSetValues.ElementAtOrDefault(i);
                                <div class="reps-set-group text-center" style="width:90px">
                                    <label class="form-label small text-muted mb-1">Set @(i + 1)</label>
                                    <input type="number" name="RepsPerSetValues[@i]" value="@(reps > 0 ? reps : 10)"
                                           class="form-control text-center" min="1" max="200" />
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="WeightKg" class="form-label">Weight (kg)</label>
                        <div class="input-group" style="max-width:220px">
                            <input asp-for="WeightKg" class="form-control" type="number" step="0.5" min="0" placeholder="0" />
                            <span class="input-group-text">kg</span>
                        </div>
                        <span asp-validation-for="WeightKg" class="text-danger"></span>
                    </div>
                </div>

                <div id="cardio-fields" style="display:none">
                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label asp-for="DurationMinutes" class="form-label">Duration (minutes)</label>
                            <input asp-for="DurationMinutes" class="form-control" type="number" step="0.5" min="0" placeholder="e.g. 30" />
                            <span asp-validation-for="DurationMinutes" class="text-danger"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="DistanceKm" class="form-label">Distance (km)</label>
                            <input asp-for="DistanceKm" class="form-control" type="number" step="0.01" min="0" placeholder="e.g. 5.0" />
                            <span asp-validation-for="DistanceKm" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="mb-3 d-flex align-items-center gap-2">
                    <span class="text-muted small">Estimated calories burned:</span>
                    <span id="cal-preview" class="fw-bold text-primary small">
                        @(Model.CaloriesBurned.HasValue ? $"~{Model.CaloriesBurned} kcal" : "—")
                    </span>
                </div>

                <div class="mb-3">
                    <label asp-for="Notes" class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Save changes</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/exercise-form.js" asp-append-version="true"></script>
}
