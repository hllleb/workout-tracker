@model WorkoutTracker.ViewModels.ExerciseEntryEditViewModel

@{
    ViewData["Title"] = "Edit exercise";
    var workoutName = ViewData["WorkoutName"] as string;
}

<h1>Edit exercise</h1>
@if (!string.IsNullOrWhiteSpace(workoutName))
{
    <p class="text-muted">Workout: <strong>@workoutName</strong></p>
}

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="WorkoutId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Sets" class="form-label"></label>
                <input asp-for="Sets" class="form-control" type="number" min="1" max="50" />
                <span asp-validation-for="Sets" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Reps" class="form-label"></label>
                <input asp-for="Reps" class="form-control" type="number" min="1" max="200" />
                <span asp-validation-for="Reps" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="WeightKg" class="form-label"></label>
                <input asp-for="WeightKg" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="WeightKg" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-link" asp-controller="Workouts" asp-action="Details" asp-route-id="@Model.WorkoutId">Back</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
