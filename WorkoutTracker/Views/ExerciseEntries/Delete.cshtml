@model WorkoutTracker.Models.ExerciseEntry

@{
    ViewData["Title"] = "Delete exercise";
    var workoutName = ViewData["WorkoutName"] as string;
}

<h1>Delete exercise</h1>
@if (!string.IsNullOrWhiteSpace(workoutName))
{
    <p class="text-muted">Workout: <strong>@workoutName</strong></p>
}

<h3>Are you sure you want to delete this exercise?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">Sets</dt>
        <dd class="col-sm-10">@Model.Sets</dd>
        <dt class="col-sm-2">Reps</dt>
        <dd class="col-sm-10">@Model.Reps</dd>
        <dt class="col-sm-2">Weight</dt>
        <dd class="col-sm-10">@(Model.WeightKg.HasValue ? $"{Model.WeightKg:0.##} kg" : "-")</dd>
        <dt class="col-sm-2">Notes</dt>
        <dd class="col-sm-10">@Model.Notes</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a class="btn btn-link" asp-controller="Workouts" asp-action="Details" asp-route-id="@Model.WorkoutId">Back</a>
    </form>
</div>
