@model WorkoutTracker.Models.Meal

@{
    ViewData["Title"] = "Delete meal";
}

<h1>Delete meal</h1>

<h3>Are you sure you want to delete this meal?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">Consumed at</dt>
        <dd class="col-sm-10">@Model.ConsumedAt.ToString("yyyy-MM-dd HH:mm")</dd>
        <dt class="col-sm-2">Notes</dt>
        <dd class="col-sm-10">@Model.Notes</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a class="btn btn-link" asp-action="Index">Back to list</a>
    </form>
</div>
