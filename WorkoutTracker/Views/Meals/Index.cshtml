@model WorkoutTracker.ViewModels.MealsIndexViewModel

@{
    ViewData["Title"] = "Meals";
}

<h1>Meals</h1>

<p>
    <a class="btn btn-primary" asp-action="Create">Add meal</a>
</p>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-4">
        <label class="form-label" for="search">Search by name</label>
        <input type="text" class="form-control" id="search" name="search" value="@Model.Search" />
    </div>
    <div class="col-md-3">
        <label class="form-label" for="fromDate">From date</label>
        <input type="date" class="form-control" id="fromDate" name="fromDate"
               value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" />
    </div>
    <div class="col-md-3">
        <label class="form-label" for="toDate">To date</label>
        <input type="date" class="form-control" id="toDate" name="toDate"
               value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" />
    </div>
    <div class="col-md-2 d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-secondary">Filter</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Clear</a>
    </div>
</form>

@if (Model.DailyTotals.Count > 0)
{
    <div class="mb-4">
        <h2>Daily totals</h2>
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Calories</th>
                    <th>Protein</th>
                    <th>Carbs</th>
                    <th>Fat</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var total in Model.DailyTotals)
            {
                <tr>
                    <td>@total.Date.ToString("yyyy-MM-dd")</td>
                    <td>@total.Calories</td>
                    <td>@total.ProteinG.ToString("0.##")</td>
                    <td>@total.CarbsG.ToString("0.##")</td>
                    <td>@total.FatG.ToString("0.##")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@if (Model.Meals.Count == 0)
{
    <p class="text-muted">No meals found.</p>
}
else
{
<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Consumed at</th>
            <th>Calories</th>
            <th>Notes</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Meals)
    {
        var calories = item.Items.Sum(i => i.Calories);
        <tr>
            <td>@item.Name</td>
            <td>@item.ConsumedAt.ToString("yyyy-MM-dd HH:mm")</td>
            <td>@calories</td>
            <td>@item.Notes</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
}
