@model WorkoutTracker.ViewModels.MealsIndexViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Meals";
    var chartTotals = Model.DailyTotals.OrderBy(t => t.Date).ToList();
    var chartJson = JsonSerializer.Serialize(chartTotals.Select(t => new
    {
        date = t.Date.ToString("yyyy-MM-dd"),
        calories = t.Calories,
        proteinG = t.ProteinG,
        carbsG = t.CarbsG,
        fatG = t.FatG
    }));
}

<div class="page-header">
    <div>
        <h1>Meals</h1>
        <p>Log nutrition, filter history, and review daily macro trends.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Add meal</a>
</div>

<form method="get" class="row g-3 filter-card">
    <div class="col-md-4">
        <label class="form-label" for="search">Search by name</label>
        <input type="text" class="form-control" id="search" name="search" value="@Model.Search" />
    </div>
    <div class="col-md-3">
        <label class="form-label" for="fromDate">From date</label>
        <input type="date" class="form-control" id="fromDate" name="fromDate"
               value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" />
    </div>
    <div class="col-md-3">
        <label class="form-label" for="toDate">To date</label>
        <input type="date" class="form-control" id="toDate" name="toDate"
               value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" />
    </div>
    <div class="col-md-2 d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-secondary">Filter</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Clear</a>
    </div>
</form>

@if (Model.DailyTotals.Count > 0)
{
    <section class="panel">
        <h2 class="h4">Daily nutrition</h2>
        <div class="row mb-4">
            <div class="col-lg-6 mb-3">
                <canvas id="caloriesChart" aria-label="Daily calories chart"></canvas>
            </div>
            <div class="col-lg-6 mb-3">
                <canvas id="macrosChart" aria-label="Daily macros chart"></canvas>
            </div>
        </div>
        <h3 class="h6 text-uppercase text-muted">Daily totals</h3>
        <div class="table-card">
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Calories</th>
                        <th>Protein</th>
                        <th>Carbs</th>
                        <th>Fat</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var total in Model.DailyTotals)
                {
                    <tr>
                        <td>@total.Date.ToString("yyyy-MM-dd")</td>
                        <td>@total.Calories</td>
                        <td>@total.ProteinG.ToString("0.##")</td>
                        <td>@total.CarbsG.ToString("0.##")</td>
                        <td>@total.FatG.ToString("0.##")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
}

@if (Model.Meals.Count == 0)
{
    <div class="empty-state">No meals found.</div>
}
else
{
    <div class="table-card">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Consumed at</th>
                    <th>Calories</th>
                    <th>Notes</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Meals)
            {
                var calories = item.Items.Sum(i => i.Calories);
                <tr>
                    <td class="fw-semibold">@item.Name</td>
                    <td>@item.ConsumedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@calories</td>
                    <td class="text-muted">@item.Notes</td>
                    <td class="table-actions text-end">
                        <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    @if (Model.DailyTotals.Count > 0)
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
        <script src="~/js/meals-charts.js" asp-append-version="true"></script>
        <script>
            initMealsCharts(@Html.Raw(chartJson));
        </script>
    }
}
