@model WorkoutTracker.ViewModels.MealEditViewModel

@{
    ViewData["Title"] = "Create meal";
}

<h1>Create meal</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ConsumedAt" class="form-label"></label>
                <input asp-for="ConsumedAt" class="form-control" type="datetime-local" />
                <span asp-validation-for="ConsumedAt" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Create</button>
            <a class="btn btn-link" asp-action="Index">Back to list</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
