@model WorkoutTracker.Models.Meal

@{
    ViewData["Title"] = "Meal details";
}

<h1>Meal details</h1>

<div>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">Consumed at</dt>
        <dd class="col-sm-10">@Model.ConsumedAt.ToString("yyyy-MM-dd HH:mm")</dd>
        <dt class="col-sm-2">Notes</dt>
        <dd class="col-sm-10">@Model.Notes</dd>
        <dt class="col-sm-2">Items</dt>
        <dd class="col-sm-10">@Model.Items.Count</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> |
    <a asp-action="Index">Back to list</a>
</div>
